  - name: image_b64_decode
    type: function
    desc: |
      ImageB64Decode.
    parameters:
    - name: data
      type: string
    - name: length
      type: number
    returns:
    - name: decoded
      type: string
      desc: |
        Data
        

  - name: image_load_data
    type: function
    desc: |
      ImageLoadData.
    parameters:
    - name: filename
      type: string
    - name: data
      type: string
    - name: data_length
      type: number
    returns:
    - name: texture_id
      type: number
    - name: width
      type: number
    - name: height
      type: number

  - name: image_load
