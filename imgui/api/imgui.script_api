  - name: begin_popup_context_item
    type: function
    desc: |
      BeginPopupContextItem.
      If id is omitted, uses the last item ID (same as ImGui helper behavior). Lua - call with no arguments to use the last item; passing nil is not accepted.
    parameters:
    - name: id
      type: string
      desc: |
        Optional; if omitted, uses the last item ID.
        
    returns:
    - name: result
      type: boolean

